#!/bin/sh
set -e

. /usr/share/debconf/confmodule

CTRLDIR=/etc/qmail

# Legacy qmail installations keep control files under /var/qmail/control/.
# Check both locations, preferring the current layout.
_read_ctrl() {
    fname="$1"
    if [ -f "$CTRLDIR/$fname" ]; then
        cat "$CTRLDIR/$fname"
    elif [ -d /var/qmail/control ] && [ ! -L /var/qmail/control ] \
            && [ -f "/var/qmail/control/$fname" ]; then
        cat "/var/qmail/control/$fname"
    fi
}

# Seed hostname: prefer existing me file, then hostname -f
CURRENT_HN=$(_read_ctrl me)
[ -z "$CURRENT_HN" ] && CURRENT_HN=$(hostname -f 2>/dev/null || echo "")

db_get qmail/hostname
[ -z "$RET" ] && db_set qmail/hostname "$CURRENT_HN"

# Seed domain: prefer existing defaultdomain, then strip host component
CURRENT_DOMAIN=$(_read_ctrl defaultdomain)
if [ -z "$CURRENT_DOMAIN" ] && [ -n "$CURRENT_HN" ]; then
    CURRENT_DOMAIN=$(echo "$CURRENT_HN" | sed 's/^[^.]*\.//')
fi

db_get qmail/domain
[ -z "$RET" ] && db_set qmail/domain "$CURRENT_DOMAIN"

db_input high qmail/hostname || true
db_input high qmail/domain || true
db_go || true
