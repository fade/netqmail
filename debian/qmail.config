#!/bin/sh
set -e

. /usr/share/debconf/confmodule

CTRLDIR=/etc/qmail

# Seed hostname: prefer existing control/me, then hostname -f
CURRENT_HN=""
[ -f "$CTRLDIR/me" ] && CURRENT_HN=$(cat "$CTRLDIR/me")
[ -z "$CURRENT_HN" ] && CURRENT_HN=$(hostname -f 2>/dev/null || echo "")

db_get qmail/hostname
[ -z "$RET" ] && db_set qmail/hostname "$CURRENT_HN"

# Seed domain: prefer existing control/defaultdomain, then strip host part
CURRENT_DOMAIN=""
[ -f "$CTRLDIR/defaultdomain" ] && CURRENT_DOMAIN=$(cat "$CTRLDIR/defaultdomain")
if [ -z "$CURRENT_DOMAIN" ] && [ -n "$CURRENT_HN" ]; then
    CURRENT_DOMAIN=$(echo "$CURRENT_HN" | sed 's/^[^.]*\.//')
fi

db_get qmail/domain
[ -z "$RET" ] && db_set qmail/domain "$CURRENT_DOMAIN"

db_input high qmail/hostname || true
db_input high qmail/domain || true
db_go || true
