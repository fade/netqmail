#. Type: string
#. Description
#: ../qmail.templates:1001
msgid "Fully qualified domain name for this mail server"
msgstr ""

#. Type: string
#. Description
#: ../qmail.templates:1001
msgid ""
"Enter the fully qualified domain name (FQDN) that this mail server will use "
"to identify itself in SMTP conversations. This becomes the value of the 'me' "
"control file and is passed to config-fast to initialise the qmail control "
"files."
msgstr ""

#. Type: string
#. Description
#: ../qmail.templates:1001
msgid "Example: mail.example.com"
msgstr ""

#. Type: string
#. Description
#: ../qmail.templates:2001
msgid "Primary mail domain"
msgstr ""

#. Type: string
#. Description
#: ../qmail.templates:2001
msgid ""
"Enter the primary domain for which this server accepts mail. This will be "
"added to the 'locals' and 'rcpthosts' control files, and used as the signing "
"domain when generating DKIM keys."
msgstr ""

#. Type: string
#. Description
#: ../qmail.templates:2001
msgid "Example: example.com"
msgstr ""
